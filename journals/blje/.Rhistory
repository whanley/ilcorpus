paste(collapse=" ") %>%
gsub("\\s+", " ", .)
text <- d %>%
xml_find_all(".//d1:p") %>%
xml_text() %>%
paste(collapse=" ") %>%
gsub("\\s+", " ", .)
count <- length(tokenize_words(text)[[1]])
tibble(head=header, count)
})
#bind everything up into a tibble.
answer <- do.call(rbind, output)
