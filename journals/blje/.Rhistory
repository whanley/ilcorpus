blje_langs <- lapply(blje_files, extract_lang_data)
one_list <- do.call(rbind, blje_langs)
blje_langs_tibble <- as_tibble(one_list, .name_repair = "minimal")
# load lang names file
lang_names <- read_tsv("~/GitHub/ilcorpus/codes/lang-codes.tsv")
# get mean word count and count of reports, join with lang names
blje_langs_sum <- blje_langs_tibble %>%
group_by(lang_code) %>%
summarise(words = mean(count), reports = n()) %>%
left_join(lang_names)
